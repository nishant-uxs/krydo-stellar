{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "rm -f package-lock.json && NPM_CONFIG_PRODUCTION=false npm install --include=optional --include=dev && npm run build",
  "outputDirectory": "dist/public",
  "installCommand": "NPM_CONFIG_PRODUCTION=false npm install --include=optional --include=dev",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/healthz", "destination": "/api" },
    { "source": "/readyz", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
